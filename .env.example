VITE_API_BASE_URL=https://api.glasspay.app

# Public URL of this app — used for absolute URLs (e.g. invite links, canonical URLs).
VITE_APP_URL=https://app.glasspay.app

# Required for the "Continue with Google" buttons on the sign-up/sign-in
# pages to work. Create an OAuth 2.0 Client ID (type: Web application) in
# Google Cloud Console > APIs & Services > Credentials, and add this app's
# origin(s) (e.g. http://localhost:5173 for dev, https://app.glasspay.app
# for prod) under "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Controls the test-mode banner on the Payment Summary screen (shown by default).
# Set to "false" in your deployment environment when switching to Paystack live keys.
# VITE_TEST_MODE=false

# Optional. Enables crash/error reporting (src/utils/monitoring.js) via
# Sentry — render crashes and 5xx/network API errors get reported; routine
# 4xx validation errors are filtered out as expected user-facing feedback,
# not bugs. Leave unset to run with monitoring disabled (e.g. local dev).
# Create a project at sentry.io and paste its DSN here.
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
