VITE_API_BASE_URL=https://api.glasspay.app

# Required for the "Continue with Google" buttons on the sign-up/sign-in
# pages to work. Create an OAuth 2.0 Client ID (type: Web application) in
# Google Cloud Console > APIs & Services > Credentials, and add this app's
# origin(s) (e.g. http://localhost:5173 for dev, https://app.glasspay.app
# for prod) under "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
